# WeRead data access
# Use the API key/token required by your installed WeRead Skill or compatible data source.
WEREAD_API_KEY=wrk-your-api-key

# Data source options:
# - official-skill: read data through an installed WeRead Skill
# - local-json: read data from a local JSON file for testing
# - custom-api: read data from your own API adapter
WEREAD_DATA_SOURCE=official-skill

# Default analysis range: 7d, 30d, 90d, year
WEREAD_DEFAULT_RANGE=30d

# Default insight lens: default, deep, decision, content, review, self
WEREAD_DEFAULT_LENS=default

# Export directory for generated HTML / Markdown reports
WEREAD_EXPORT_DIR=exports

# Optional local JSON data source for testing
# WEREAD_LOCAL_DATA=examples/sample-reading-data.json
